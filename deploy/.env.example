# Moebius Server — Docker Compose Configuration
# Copy to .env and edit before running: cp .env.example .env

# Required ─────────────────────────────────────────────────
SERVER_DOMAIN=manage.example.com
POSTGRES_PASSWORD=changeme

# Optional overrides ───────────────────────────────────────
# VERSION=latest
# LOG_LEVEL=info
# LOG_FORMAT=json
# REAPER_DISPATCHED_TIMEOUT_SECONDS=300
# REAPER_INFLIGHT_TIMEOUT_SECONDS=3600

# S3 storage (set STORAGE_BACKEND=s3 in docker-compose.yml to use)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=my-moebius-files
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# SMTP for alert emails (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=moebius@example.com
